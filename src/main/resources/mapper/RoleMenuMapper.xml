<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.myadminjavaeight.mapper.RoleMenuMapper">
    <insert id="batchInsert">
        INSERT INTO sys_role_menu (role_id, menu_id)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.roleId}, #{item.menuId})
        </foreach>
    </insert>

    <delete id="deleteByRoleId">
        DELETE FROM sys_role_menu WHERE role_id = #{roleId}
    </delete>

    <select id="findByRoleId" resultType="org.example.jwtjavaeight.domain.entity.SysRoleMenu">
        SELECT id, role_id, menu_id, create_time
        FROM sys_role_menu
        WHERE role_id = #{roleId}
    </select>

    <delete id="deleteByRoleIdAndMenuId">
        DELETE FROM sys_role_menu
        WHERE role_id = #{roleId} AND menu_id = #{menuId}
    </delete>
</mapper>